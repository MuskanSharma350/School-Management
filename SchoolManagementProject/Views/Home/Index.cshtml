@{
    ViewData["Title"] = "Home";
    var userName = User.Identity?.Name ?? "User";
}
<style>
    body {
        font-family: 'Poppins', sans-serif;
        background-color: #f8f9fc;
    }

    .fw-600 { font-weight: 600; }

    .hover-up {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border-radius: 12px;
    }

    .hover-up:hover {
        transform: translateY(-8px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important;
    }

    .icon-circle {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
    }

    .bg-primary-soft { background-color: #eef2ff; }
    .bg-success-soft { background-color: #f0fdf4; }
    .bg-info-soft { background-color: #e0f7fa; }

    .btn-rounded-pill {
        border-radius: 50px;
    }
    #movetop {
        display: none; 
        position: fixed;
        bottom: 20px;
        right: 30px;
        z-index: 99;
        border: none;
        outline: none;
        background-color: #0d6efd; 
        color: white;
        cursor: pointer;
        padding: 15px;
        border-radius: 50%;
        width: 50px;
        height: 50px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
        transition: 0.3s;
    }

    #movetop:hover {
        background-color: #0056b3;
        transform: scale(1.1);
    }
    .homePage {
    padding-top: 80px !important;
}
</style>
<div class="container-fluid animate__animated animate__fadeIn homePage">
    <div class="row mt-4 mb-4 fix_div-hm">
        <div class="col-12">
            <div class="p-5 mb-4 bg-white shadow-sm" style="border-radius: 15px; border-left: 5px solid #4e73df;">
                
                <p class="lead text-muted mb-0">Hello, <span class="text-primary fw-600">@userName</span>. Welcome to your school portal.</p>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm hover-up">
                <div class="card-body p-4 text-center">
                    <div class="icon-circle bg-primary-soft mb-3">
                        <i class="fas fa-th-large text-primary fs-3"></i>
                    </div>
                    <h5 class="fw-bold">My Dashboard</h5>
                    <p class="small text-muted">Access your main activity overview and schedules.</p>
                    <a href="/Dashboard/AdminDashboard" class="btn btn-outline-primary btn-sm rounded-pill px-4 mt-2">Open</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm hover-up">
                <div class="card-body p-4 text-center">
                    <div class="icon-circle bg-success-soft mb-3">
                        <i class="fas fa-user-circle text-success fs-3"></i>
                    </div>
                    <h5 class="fw-bold">Account Settings</h5>
                    <p class="small text-muted">Manage your profile, password, and security settings.</p>
                    <a href="/Account/ChangeUser" class="btn btn-outline-success btn-sm rounded-pill px-4 mt-2">Manage</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm hover-up">
                <div class="card-body p-4 text-center">
                    <div class="icon-circle bg-info-soft mb-3">
                        <i class="fas fa-info-circle text-info fs-3"></i>
                    </div>
                    <h5 class="fw-bold">Resources</h5>
                    <p class="small text-muted">Helpful documentation and school guide materials.</p>
                    <a href="#" class="btn btn-outline-info btn-sm rounded-pill px-4 mt-2">View</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-5">
        <div class="col-12 text-center text-muted">
            <p class="small">© @DateTime.Now.Year - Muskan Academy Management System</p>
        </div>
    </div>
</div>
<button onclick="topFunction()" id="movetop" title="Go to top">
    <i class="fas fa-arrow-up"></i>
</button>
