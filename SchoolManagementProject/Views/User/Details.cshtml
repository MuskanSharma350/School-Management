@model SchoolManagementSystem.Models.User
@{
    Layout = "_Dashboard";
    ViewBag.PageTitle = "Users";
    ViewBag.SubPageTitle = "Details";
    ViewData["Title"] = "User Details";
}

<h2 class="headingClass">User Account Details</h2>

<div class="card border-0 shadow-sm" style="border-radius: 15px;">
    <div class="card-body p-4">
        <div class="row">
            <!-- Profile Icon/Image Section -->
            <div class="col-md-3 text-center mb-4 mb-md-0">
                <div class="profile-placeholder mb-3">
                    <i class="fas fa-user-circle text-primary" style="font-size: 150px;"></i>
                </div>
                <span class="badge bg-info p-2 px-3 rounded-pill">System User</span>
            </div>

            <!-- Information Section -->
            <div class="col-md-9">
                <div class="d-flex justify-content-between align-items-center">
                    <h3 class="fw-bold text-dark">@Model.FirstName @Model.LastName</h3>
                    <span class="text-muted small">ID: @Model.Id</span>
                </div>
                <hr />
                
                <dl class="row mt-4">
                    <dt class="col-sm-4 text-muted mb-3" data-toggle="tooltip" title="The unique username used for login">
                        <i class="fas fa-id-badge me-2"></i> Username:
                    </dt>
                    <dd class="col-sm-8 fw-bold">@Model.UserName</dd>

                    <dt class="col-sm-4 text-muted mb-3" data-toggle="tooltip" title="Primary email address">
                        <i class="fas fa-envelope me-2"></i> Email Address:
                    </dt>
                    <dd class="col-sm-8">@Model.Email</dd>

                    <dt class="col-sm-4 text-muted mb-3" data-toggle="tooltip" title="The date this account was created">
                        <i class="fas fa-calendar-alt me-2"></i> Member Since:
                    </dt>
                    <dd class="col-sm-8">@Model.DateCreated.ToString("MMMM dd, yyyy")</dd>

                    <dt class="col-sm-4 text-muted mb-3" data-toggle="tooltip" title="Residential address of the user">
                        <i class="fas fa-map-marker-alt me-2"></i> Address:
                    </dt>
                    <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.Address) ? "Not Provided" : Model.Address)</dd>
                </dl>

                <!-- Actions Footer -->
                <div class="mt-4 pt-3 border-top">
                    <div class="d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning px-4 rounded-pill shadow-sm">
                            <i class="fas fa-edit me-1"></i> Edit User
                        </a>
                        <a asp-action="Index" class="btn btn-secondary px-4 rounded-pill">
                            <i class="fas fa-list me-1"></i> Back to List
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger px-4 rounded-pill ms-auto">
                            <i class="fas fa-trash-alt me-1"></i> Delete
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            // Initialize Bootstrap Tooltips
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-toggle="tooltip"]'))
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl)
            })
        });
    </script>
}

<style>
    .headingClass {
        font-weight: 600;
        color: #333;
        margin-bottom: 25px;
    }

    dt {
        font-weight: 500;
    }

    .profile-placeholder {
        background-color: #f8f9fa;
        display: inline-block;
        padding: 10px;
        border-radius: 50%;
        border: 4px solid #fff;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }
</style>