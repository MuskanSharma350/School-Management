@model SchoolManagementProject.Models.User
@{
    Layout = "_Dashboard";
    ViewBag.PageTitle = "Users";
    ViewBag.SubPageTitle = "Delete";
    ViewData["Title"] = "Delete User";
}

<div class="container mt-4">
    <h2 class="text-danger">Delete User</h2>

    <h3>Are you sure you want to delete this user?</h3>
    <hr />
    <div class="card mb-3 shadow">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-2">User Name</dt>
                <dd class="col-sm-10">@Model.FullName</dd>
            </dl>
            <dl class="row">
                <dt class="col-sm-2">Email</dt>
                <dd class="col-sm-10">@Model.Email</dd>
            </dl>
        </div>
    </div>

    <form id="deleteForm" asp-action="DeleteConfirmed" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="button" class="btn btn-danger" id="confirmDelete">
            <i class="fas fa-trash-alt"></i> Delete
        </button>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-times"></i> Cancel
        </a>
    </form>
</div>

@section Scripts {
    <script src="~/js/formHelpers.js"></script>
    <script>
        setupSweetAlertOnDelete("confirmDelete", "deleteForm", "You won't be able to revert this!");
    </script>
}
